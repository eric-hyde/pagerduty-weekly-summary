# PagerDuty Configuration
PD_API_TOKEN=your_pagerduty_api_token_here
PD_TEAM_IDS=TEAM_ID_1,TEAM_ID_2
PD_TEAM_NAME=Observability
PD_SCHEDULES=SCHEDULE_ID_1,SCHEDULE_ID_2
PD_TIMEZONE=America/Chicago

# Slack Workflow Webhook URL
# Get this from your Slack workspace: Workflow Builder -> Create Workflow -> Add Webhook Trigger
SLACK_WORKFLOW_WEBHOOK_URL=https://hooks.slack.com/triggers/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

# Ollama Configuration
OLLAMA_MODEL=llama3:8b
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Cron scheduling
ENABLE_CRON=false
CRON_EXPR=0 9 * * 1
CRON_TZ=America/Chicago

# Optional: Debug logging
DEBUG=false
